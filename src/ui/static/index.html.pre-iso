  bubbleBorder: 'rgba(255,255,255,0.1)',
  bubbleText: '#EEE',
  bubbleArrow: 'rgba(30,34,42,0.92)',
  bubbleArrowBorder: 'rgba(255,255,255,0.1)',

  /* ── HUD / Scene ── */
