<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Enterprise HQ — Corporate Simulation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/pixi.js@8/dist/pixi.min.js"></script>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #0d1117; --bg2: #161b22; --border: #30363d;
  --text: #e6edf3; --dim: #8b949e;
  --red: #e94560; --green: #2ecc71; --yellow: #f39c12; --blue: #4A90D9; --purple: #9B59B6;
}
body { font-family: 'Outfit', 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: var(--text); overflow: hidden; height: 100vh; }
#app { display: grid; grid-template-rows: 48px 1fr; grid-template-columns: 1fr 320px; grid-template-areas: "hd hd" "cv sb"; height: 100vh; }

/* Header */
#hdr { grid-area: hd; display: flex; align-items: center; justify-content: space-between; padding: 0 16px; background: var(--bg2); border-bottom: 1px solid var(--border); }
#hdr h1 { font-size: 1.05em; color: var(--red); }
.dot { width: 8px; height: 8px; border-radius: 50%; background: #e74c3c; display: inline-block; margin-right: 8px; }
.dot.on { background: var(--green); }
#step-lbl { font-size: 0.85em; color: var(--yellow); }
#timer { font-size: 0.8em; color: var(--dim); font-variant-numeric: tabular-nums; }

/* Canvas area */
#cv-wrap { grid-area: cv; display: flex; align-items: center; justify-content: center; background: #0a0a18; overflow: hidden; }
#game { border-radius: 4px; max-width: 100%; max-height: 100%; }

/* Sidebar */
#sb { grid-area: sb; display: flex; flex-direction: column; background: var(--bg2); border-left: 1px solid var(--border); overflow: hidden; }
#sb h3 { padding: 10px 14px 6px; font-size: 0.75em; color: var(--dim); text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid var(--border); }
#log-wrap { flex: 1; overflow-y: auto; }
#log { padding: 6px 14px; }
.le { padding: 3px 0; font-size: 0.78em; border-bottom: 1px solid rgba(255,255,255,0.03); animation: fi .3s; }
.le .t { color: var(--dim); margin-right: 6px; font-size: 0.85em; }
.le.ceo { color: var(--blue); } .le.leader { color: var(--green); }
.le.worker { color: var(--red); } .le.system { color: var(--yellow); } .le.error { color: #e74c3c; font-weight: 600; }
.le.hide-filter { display: none; }
@keyframes fi { from { opacity:0; transform:translateY(-3px); } to { opacity:1; transform:translateY(0); } }
#log-filters { display: flex; gap: 4px; padding: 6px 14px 4px; flex-wrap: wrap; }
.log-chip { padding: 2px 8px; border-radius: 10px; font-size: 0.7em; border: 1px solid var(--border); background: transparent; color: var(--dim); cursor: pointer; transition: all .15s; }
.log-chip.active { background: var(--border); color: var(--text); }
#org-panel { border-top: 1px solid var(--border); max-height: 200px; overflow-y: auto; }
#org { padding: 8px 14px; font-size: 0.78em; }
.ol { margin-bottom: 4px; } .ol .dn { font-weight: 600; color: var(--green); }
.ow { margin-left: 16px; color: var(--dim); }
.ow .status-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; margin-right: 4px; vertical-align: middle; }
.ow .status-dot.working { background: var(--yellow); animation: pulse-dot 1.5s infinite; }
.ow .status-dot.done { background: var(--green); }
.ow .status-dot.idle { background: var(--dim); }
@keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:0.4} }

/* ── Overlay System ── */
@keyframes ov-fade { from { opacity: 0; } to { opacity: 1; } }
@keyframes ov-card-in { from { opacity: 0; transform: translateY(18px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
@keyframes ov-shimmer { 0% { background-position: -200% center; } 100% { background-position: 200% center; } }

.ov {
  position: fixed; inset: 0; display: flex; align-items: center; justify-content: center;
  z-index: 100; animation: ov-fade 0.25s ease;
  background: radial-gradient(ellipse at 50% 40%, rgba(13,17,23,0.82), rgba(0,0,0,0.92));
  backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
}
.ov.h { display: none; }

.oc {
  background: linear-gradient(168deg, #1a2233 0%, #131920 100%);
  border: 1px solid rgba(233,69,96,0.15);
  border-radius: 20px; padding: 36px 34px;
  max-width: 620px; width: 92%; max-height: 82vh; overflow-y: auto;
  box-shadow: 0 0 0 1px rgba(255,255,255,0.03), 0 8px 32px rgba(0,0,0,0.45), 0 32px 72px rgba(0,0,0,0.25);
  animation: ov-card-in 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
}
.oc::before {
  content: ''; position: absolute; top: 0; left: 40px; right: 40px; height: 2px;
  background: linear-gradient(90deg, transparent 0%, var(--red) 30%, var(--purple) 70%, transparent 100%);
  border-radius: 0 0 2px 2px; opacity: 0.8;
}
.oc::-webkit-scrollbar { width: 6px; }
.oc::-webkit-scrollbar-track { background: transparent; }
.oc::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 3px; }

.oc h2 { margin-bottom: 16px; font-size: 1.3em; font-weight: 600; letter-spacing: -0.01em; }

.oc textarea {
  width: 100%; min-height: 70px; padding: 14px 16px; margin: 10px 0;
  background: rgba(10,14,20,0.6); color: var(--text);
  border: 1px solid rgba(48,54,61,0.7); border-radius: 12px;
  font-family: inherit; font-size: 0.92em; resize: vertical; line-height: 1.6;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.oc textarea:focus {
  outline: none; border-color: rgba(233,69,96,0.45);
  box-shadow: 0 0 0 3px rgba(233,69,96,0.08), 0 0 20px rgba(233,69,96,0.06);
}
.oc textarea::placeholder { color: rgba(139,148,158,0.6); }

.oc button {
  padding: 11px 26px; margin: 4px; border: none; border-radius: 10px;
  font-size: 0.88em; cursor: pointer; font-weight: 600; font-family: inherit;
  letter-spacing: 0.01em; position: relative;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.oc button:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.3); filter: brightness(1.12); }
.oc button:active { transform: translateY(0); filter: brightness(0.95); }

.bp { background: linear-gradient(135deg, var(--red) 0%, #c0392b 100%); color: #fff; }
.bs { background: rgba(48,54,61,0.7); color: var(--text); border: 1px solid rgba(48,54,61,0.5); }
.bc { background: linear-gradient(135deg, var(--green) 0%, #219a52 100%); color: #fff; }
.bd { background: linear-gradient(135deg, #e74c3c 0%, #b83227 100%); color: #fff; }

.ds {
  margin: 16px 0; padding: 16px;
  background: rgba(10,14,20,0.45); border-radius: 14px;
  border: 1px solid rgba(48,54,61,0.4); border-left: 3px solid var(--green);
}
.ds h3 { font-size: 0.95em; margin-bottom: 8px; font-weight: 600; }
.qi { margin: 10px 0; }
.qi p { font-size: 0.88em; margin-bottom: 5px; line-height: 1.55; color: rgba(230,237,243,0.9); }
.rs {
  background: rgba(10,14,20,0.5); padding: 16px; border-radius: 12px;
  font-size: 0.82em; white-space: pre-wrap; max-height: 300px; overflow-y: auto;
  margin: 14px 0; border: 1px solid rgba(48,54,61,0.35); line-height: 1.65;
}
.ra { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; }
.cc { text-align: center; } .cc h2 { color: var(--green); }

#task-ov .oc { text-align: center; padding: 44px 38px; }
#task-in { min-height: 90px; font-size: 1em; text-align: left; }

/* ── Phase 3: Interaction Enhancement ── */
/* Character popup card */
.char-popup {
  position: fixed; z-index: 90; pointer-events: auto;
  animation: ov-card-in 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}
.cp-card {
  background: linear-gradient(168deg, #1a2233 0%, #131920 100%);
  border: 1px solid rgba(233,69,96,0.2); border-radius: 14px;
  padding: 16px 18px; min-width: 220px; max-width: 280px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5);
}
.cp-header {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 10px; padding-bottom: 8px;
  border-bottom: 1px solid var(--border);
}
.cp-header .cp-emoji { font-size: 1.6em; }
.cp-header .cp-name { font-weight: 600; font-size: 0.95em; }
.cp-header .cp-title { font-size: 0.75em; color: var(--dim); }
.cp-close {
  position: absolute; top: 8px; right: 10px; background: none; border: none;
  color: var(--dim); cursor: pointer; font-size: 1.1em; padding: 2px 6px;
  border-radius: 4px; transition: color 0.15s;
}
.cp-close:hover { color: var(--text); }
.cp-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 3px 0; font-size: 0.8em;
}
.cp-row .cp-label { color: var(--dim); }
.cp-row .cp-value { color: var(--text); }
.cp-progress {
  margin-top: 6px; height: 4px; border-radius: 2px;
  background: rgba(255,255,255,0.06); overflow: hidden;
}
.cp-progress-bar {
  height: 100%; border-radius: 2px;
  background: linear-gradient(90deg, var(--green), var(--blue));
  transition: width 0.3s;
}
.cp-bubbles {
  margin-top: 8px; padding-top: 6px;
  border-top: 1px solid var(--border);
}
.cp-bubbles h4 { font-size: 0.7em; color: var(--dim); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
.cp-bubble-item { font-size: 0.75em; color: var(--text); padding: 2px 0; opacity: 0.8; }

/* Room hover tooltip */
.room-tooltip {
  position: fixed; z-index: 85; pointer-events: none;
  background: rgba(22,27,34,0.95); border: 1px solid var(--border);
  border-radius: 8px; padding: 8px 12px; min-width: 140px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  font-size: 0.78em; animation: ov-fade 0.15s ease;
}
.rt-name { font-weight: 600; font-size: 0.9em; margin-bottom: 2px; }
.rt-domain { color: var(--dim); font-size: 0.8em; margin-bottom: 4px; }
.rt-occupants { color: var(--dim); font-size: 0.8em; }
.rt-occupants span { color: var(--text); }

/* Sidebar worker hover */
.ow { cursor: pointer; padding: 1px 4px; border-radius: 4px; transition: background 0.15s; }
.ow:hover { background: rgba(255,255,255,0.05); }
.ow.ow-highlight { background: rgba(243,156,18,0.15); }

/* Pinned bubble copy tooltip */
.pin-tooltip {
  position: fixed; z-index: 91; pointer-events: auto;
  background: rgba(22,27,34,0.97); border: 1px solid var(--border);
  border-radius: 10px; padding: 12px 14px; max-width: 300px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.5);
  animation: ov-card-in 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.pin-tooltip-text { font-size: 0.82em; user-select: text; -webkit-user-select: text; line-height: 1.5; margin-bottom: 8px; }
.pin-tooltip-copy {
  font-size: 0.72em; color: var(--dim); padding: 4px 10px;
  background: rgba(255,255,255,0.05); border: 1px solid var(--border);
  border-radius: 6px; cursor: pointer; transition: all 0.15s;
}
.pin-tooltip-copy:hover { background: rgba(255,255,255,0.1); color: var(--text); }

/* Log entry highlight flash */
.le-flash { background: rgba(243,156,18,0.15); transition: background 1.5s ease-out; }

/* ── Worker Progress Dashboard Panel ── */
#wp-panel {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(180deg, rgba(13,17,23,0.92) 0%, rgba(13,17,23,0.97) 100%);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid rgba(233,69,96,0.2);
  padding: 10px 16px 12px;
  z-index: 50;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  max-height: 45%;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
#wp-panel.show { transform: translateY(0); }
#wp-panel::-webkit-scrollbar { width: 4px; }
#wp-panel::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

.wp-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 8px; gap: 12px;
}
.wp-title {
  font-size: 0.8em; font-weight: 600; color: var(--red);
  display: flex; align-items: center; gap: 6px;
}
.wp-title .wp-icon { font-size: 1.1em; }
.wp-stats {
  display: flex; gap: 14px; font-size: 0.72em; color: var(--dim);
}
.wp-stats span { display: flex; align-items: center; gap: 4px; }
.wp-stats .wp-done-count { color: var(--green); font-weight: 600; }
.wp-stats .wp-running-count { color: var(--yellow); font-weight: 600; }
.wp-toggle {
  background: none; border: 1px solid var(--border); color: var(--dim);
  font-size: 0.68em; padding: 2px 8px; border-radius: 4px; cursor: pointer;
  transition: all 0.15s;
}
.wp-toggle:hover { color: var(--text); border-color: var(--dim); }

.wp-overall {
  height: 3px; border-radius: 2px;
  background: rgba(255,255,255,0.06);
  margin-bottom: 10px; overflow: hidden;
}
.wp-overall-fill {
  height: 100%; border-radius: 2px;
  background: linear-gradient(90deg, var(--red), var(--yellow), var(--green));
  transition: width 0.5s ease-out;
}

.wp-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 6px;
}
.wp-row {
  display: flex; align-items: center; gap: 8px;
  padding: 5px 8px; border-radius: 6px;
  background: rgba(255,255,255,0.02);
  transition: background 0.2s;
}
.wp-row:hover { background: rgba(255,255,255,0.05); }
.wp-row.done { opacity: 0.6; }
.wp-row.failed { opacity: 0.5; }

.wp-dot {
  width: 7px; height: 7px; border-radius: 50%;
  flex-shrink: 0; background: var(--dim);
}
.wp-dot.pending { background: var(--dim); }
.wp-dot.running { background: var(--yellow); animation: pulse-dot 1.5s infinite; }
.wp-dot.done { background: var(--green); }
.wp-dot.failed { background: #e74c3c; }

.wp-name {
  font-size: 0.72em; color: var(--text); min-width: 0;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  flex: 0 0 90px;
}

.wp-bar-wrap {
  flex: 1; height: 6px; border-radius: 3px;
  background: rgba(255,255,255,0.06); overflow: hidden;
  min-width: 50px;
}
.wp-bar-fill {
  height: 100%; border-radius: 3px;
  transition: width 0.4s ease-out, background 0.3s;
}
.wp-bar-fill.low { background: var(--red); }
.wp-bar-fill.mid { background: var(--yellow); }
.wp-bar-fill.high { background: var(--green); }

.wp-pct {
  font-size: 0.68em; color: var(--dim);
  min-width: 32px; text-align: right;
  font-variant-numeric: tabular-nums;
}
.wp-summary {
  font-size: 0.65em; color: var(--dim);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: 100px;
}
</style>
</head>
<body>
<div id="app">
  <header id="hdr">
    <div style="display:flex;align-items:center;gap:10px;"><span class="dot" id="cdot"></span><h1>Enterprise HQ</h1></div>
    <div id="step-lbl"></div>
    <div id="timer">0:00</div>
  </header>
  <div id="cv-wrap" style="position:relative;">
    <canvas id="game" width="960" height="540"></canvas>
    <div id="wp-panel">
      <div class="wp-header">
        <span class="wp-title"><span class="wp-icon">⚡</span>Worker Execution</span>
        <div class="wp-stats">
          <span>완료 <span class="wp-done-count" id="wp-done">0</span>/<span id="wp-total">0</span></span>
          <span>실행 <span class="wp-running-count" id="wp-running">0</span></span>
          <span>⏱ <span id="wp-elapsed">0:00</span></span>
        </div>
        <button class="wp-toggle" id="wp-toggle">접기</button>
      </div>
      <div class="wp-overall"><div class="wp-overall-fill" id="wp-overall-fill"></div></div>
      <div class="wp-grid" id="wp-grid"></div>
    </div>
  </div>
  <aside id="sb">
    <h3>Activity Log</h3>
    <div id="log-filters"></div>
    <div id="log-wrap"><div id="log"></div></div>
    <div id="org-panel"><h3>Organization</h3><div id="org"></div></div>
  </aside>
</div>

<div class="ov" id="task-ov">
  <div class="oc">
    <div style="font-size:2.2em;margin-bottom:6px;line-height:1;">🏢</div>
    <h2 style="font-size:1.45em;font-weight:700;letter-spacing:-0.02em;">Enterprise HQ</h2>
    <p style="color:var(--dim);margin-bottom:18px;font-size:0.88em;letter-spacing:0.03em;">AI Corporate Simulation</p>
    <textarea id="task-in" placeholder="작업을 지시해주세요&#10;예: 마케팅 전략을 수립해줘"></textarea>
    <button class="bp" id="go-btn" style="padding:13px 40px;font-size:0.95em;margin-top:6px;">시작</button>
  </div>
</div>
<div class="ov h" id="int-ov"><div class="oc" id="int-c"></div></div>
<div class="ov h" id="done-ov"><div class="oc cc" id="done-c"></div></div>

<script>
'use strict';

/* ═══════════════════════════════════════════════════
   §1  CONSTANTS
   ═══════════════════════════════════════════════════ */
const W = 960, H = 540;
const WALK_SPEED = 2.2;
const CORR_Y1 = 175, CORR_Y2 = 215, CORR_MID = 195;
const VERT_X = 235;
const LOBBY_ENTRY_Y = 395;
const FPS_INTERVAL = 1000 / 60;
const CORRIDOR_ENTRANCE_X = W + 30; /* Workers spawn off-screen right */

/* ════════════════════════════════════════════════════
   DESIGN TOKEN SYSTEM — Single Source of Truth
   All colors referenced by semantic name, never inline hex.
   Organized by: Structure → Furniture → Character → UI → FX
   ════════════════════════════════════════════════════ */
const C = {
  /* ── Building Structure ── */
  outerFloor: '#1A1A24',
  corridor: '#D5C8B0',
  corridorDark: '#4A4540',
  corridorTile: '#3E3A32',
  corridorBorder: '#2A2820',
  corridorLight: '#AAA',
  corridorDust: 'rgba(200,190,170,0.12)',
  roomFloor: '#F0E8D8',
  roomFloorDark: '#3A3830',
  roomFloorDarkTile: '#32302A',
  lobbyFloorLit: '#E8E0D0',
  execFloor: '#F5EDE0',
  execTile: '#EDE5D2',
  /* leaderFloor/leaderTile removed — leader_office no longer exists */
  roomTile: '#E8E0CE',
  wall: '#8A7E6C',
  wallDark: '#3A3630',
  wallInner: '#B0A494',
  door: '#C8BB9F',
  doorDark: '#4A4540',
  carpet: '#BFB09A',
  roomLabel: '#7A7060',
  roomLabelDark: '#4A4840',
  ceilingLight: '#DDD',
  ceilingGlow: 'rgba(255,240,200,0.2)',
  warmGlowInner: 'rgba(255,240,200,0.06)',
  domainBadgeBg: 'rgba(0,0,0,0.5)',
  elevator: '#2A2820',
  elevatorInner: '#4A4840',
  elevatorDoor: '#333',
  lobbyFloor: '#2A4A5A',
  lobbyAccent: '#5A2020',
  reception: '#5A4A30',

  /* ── Furniture ── */
  desk: '#A0845C',
  deskDark: '#7A6440',
  deskOff: '#5A4A30',      /* unlit desk fallback */
  deskTopOff: '#3A3020',   /* unlit desk surface */
  monitor: '#2A2A2A',
  monitorOff: '#1A1A1A',
  screen: '#4488CC',
  screenGlow: '#5599DD',
  screenOff: '#1A1A2A',
  screenAlt: '#88BBEE',     /* breakroom screen */
  screenAltOff: '#2A3A4A',
  chair: '#555',
  chairDark: '#2A2A2A',
  chairOff: '#222',
  whiteboard: '#F0F0F0',
  whiteboardDark: '#3A3A3A',
  sofa: '#6A5A4A',
  sofaOff: '#2A2420',
  bookshelf: '#B89860',
  phone: '#333',
  phoneBtn: '#666',
  phoneBtnOff: '#2A2A2A',
  phoneGlow: '#44DD44',
  trophy: '#B8963A',
  trophyLabel: '#FFF',
  boardSticky: ['#C25050','#5080C0','#50A050'],   /* whiteboard sticky notes */
  boardStickyOff: ['#3A2020','#202A3A','#203020'],
  nameplate: '#B89860',
  nameplateOff: '#4A3820',
  medal: '#FFD93D',
  certificate: '#DDD',

  /* ── Plants ── */
  plant: '#5A8A3A',
  plantDark: '#2A4A1A',
  plantDarker: '#1A3A0A',
  pot: '#8B6C42',
  potOff: '#3A2A1A',

  /* ── Character Palettes ── */
  skin: ['#FFDCB0','#F5D0A0','#E8C090','#D4A86C','#C49060'],
  hair: ['#2A1A0A','#4A3020','#6A4530','#8A6A40','#3A2A2A','#1A1A2A','#AA8050','#7A3A2A','#B8860B'],
  pants: ['#3A3A5A','#2A2A4A','#4A4A5A','#3A3A3A','#2A3A4A','#4A3A3A','#2A4A3A'],
  shoe: ['#2A2A2A','#3A2020','#2A2A3A','#4A3A2A','#1A1A1A'],
